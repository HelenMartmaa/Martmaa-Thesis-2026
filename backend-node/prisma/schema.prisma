// This is your Prisma schema file, learn more about it in the docs: https://pris.ly/d/prisma-schema
// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Users table
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  experiments         Experiment[]
  resultSets          ResultSet[]
  statisticalAnalyses StatisticalAnalysis[]

  @@map("users")
}

// Experiments table for planning module
model Experiment {
  id                Int       @id @default(autoincrement())
  userId            Int       @map("user_id")
  title             String    @db.VarChar(255)
  description       String
  aim               String
  experimentType    String    @map("experiment_type") @db.VarChar(20)
  organismName      String    @map("organism_name") @db.VarChar(255)
  startDate         DateTime? @map("start_date") @db.Date
  endDate           DateTime? @map("end_date") @db.Date
  scheduleNotes     String?   @map("schedule_notes")
  methodsText       String    @map("methods_text")
  resourcesText     String?   @map("resources_text")
  treatmentPlanText String?   @map("treatment_plan_text")
  notes             String?
  status            String    @db.VarChar(50)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups      ExperimentGroup[]
  subjects    ExperimentSubject[]
  teamMembers ExperimentTeamMember[]
  hypotheses  ExperimentHypothesis[]
  resultSets  ResultSet[]

  @@map("experiments")
}

// ExperimentGroup table for adding details of experiment subject groups to planned experiment
model ExperimentGroup {
  id           Int      @id @default(autoincrement())
  experimentId Int      @map("experiment_id")
  name         String   @db.VarChar(255)
  groupType    String   @map("group_type") @db.VarChar(50)
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")

  experiment Experiment          @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  subjects   ExperimentSubject[]
  entries    ResultEntry[]

  @@unique([experimentId, name])
  @@map("experiment_groups")
}

//ExperimentSubject table for adding details of experiment subject to planned experiment
model ExperimentSubject {
  id           Int      @id @default(autoincrement())
  experimentId Int      @map("experiment_id")
  groupId      Int?     @map("group_id")
  subjectCode  String   @map("subject_code") @db.VarChar(255)
  sex          String?  @db.VarChar(50)
  genotype     String?  @db.VarChar(255)
  subjectType  String?  @map("subject_type") @db.VarChar(100)
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  experiment Experiment       @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  group      ExperimentGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  entries    ResultEntry[]

  @@unique([experimentId, subjectCode])
  @@map("experiment_subjects")
}

// ExperimentTeamMember table for adding details of people and their roles in the experiment
model ExperimentTeamMember {
  id           Int      @id @default(autoincrement())
  experimentId Int      @map("experiment_id")
  memberName   String   @map("member_name") @db.VarChar(255)
  memberRole   String?  @map("member_role") @db.VarChar(255)
  memberEmail  String?  @map("member_email") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@map("experiment_team_members")
}

// ExperimentHypothesis table for adding hypothesis or hypotheses for the experiment
model ExperimentHypothesis {
  id             Int      @id @default(autoincrement())
  experimentId   Int      @map("experiment_id")
  hypothesisText String   @map("hypothesis_text")
  createdAt      DateTime @default(now()) @map("created_at")

  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@map("experiment_hypotheses")
}

// First table to analysis module for basic data information
model ResultSet {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  experimentId    Int?     @map("experiment_id")
  title           String   @db.VarChar(255)
  experimentType  String   @map("experiment_type") @db.VarChar(20)
  measurementName String   @map("measurement_name") @db.VarChar(255)
  measurementUnit String?  @map("measurement_unit") @db.VarChar(50)
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  experiment          Experiment?           @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  entries             ResultEntry[]
  statisticalAnalyses StatisticalAnalysis[]

  @@map("result_sets")
}

// Tabel for adding numerical research results data
model ResultEntry {
  id             Int     @id @default(autoincrement())
  resultSetId    Int     @map("result_set_id")
  subjectId      Int?    @map("subject_id")
  groupId        Int?    @map("group_id")
  sampleCode     String? @map("sample_code") @db.VarChar(100)
  groupLabel     String? @map("group_label") @db.VarChar(100)
  sex            String? @db.VarChar(20)
  timepointValue Float?  @map("timepoint_value")
  timepointUnit  String? @map("timepoint_unit") @db.VarChar(20)
  numericValue   Float?  @map("numeric_value")
  eventOccurred  Int?    @map("event_occurred")

  resultSet ResultSet          @relation(fields: [resultSetId], references: [id], onDelete: Cascade)
  subject   ExperimentSubject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  group     ExperimentGroup?   @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@map("result_entries")
}

// Statistical analysis table
model StatisticalAnalysis {
  id                  Int      @id @default(autoincrement())
  userId              Int      @map("user_id")
  resultSetId         Int      @map("result_set_id")
  analysisName        String   @map("analysis_name") @db.VarChar(255)
  groupingMode        String?  @map("grouping_mode") @db.VarChar(50)
  selectedMetricsJson String?  @map("selected_metrics_json")
  selectedTestsJson   String?  @map("selected_tests_json")
  filtersJson         String?  @map("filters_json")
  resultsJson         String?  @map("results_json")
  chartConfigJson     String?  @map("chart_config_json")
  createdAt           DateTime @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resultSet ResultSet @relation(fields: [resultSetId], references: [id], onDelete: Cascade)

  @@map("statistical_analyses")
}
